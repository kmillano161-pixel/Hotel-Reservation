  Asc display: Asc inline-flex;
 Asc   align-items: Asc center;
 Asc   gap Asc : Asc 0.75rem;
 Asc   background Asc : Asc rgba Asc (255, Asc Asc Asc Asc Asc Asc Asc Asc Asc 255, Asc 255, Asc 0.2);
 Asc   backdrop-filter Asc : Asc blur Asc (10px);
 Asc   color: Asc white;
 Asc   padding: Asc Asc Asc  Asc Asc Asc 1.25rem Asc Asc 3rem;
 Asc Asc   Asc Asc Asc Asc Asc   border-radius: Asc 50px;
 Asc   font-size: Asc Asc Asc 1.125rem;
 Asc   font-weight: Asc 700;
 Asc   text-decoration: Asc none;
 Asc   transition: Asc all Asc 0.4s Asc cubic-bezier Asc ( Asc Asc 0.4, Asc  Asc 0, Asc Asc Asc 0.2 Asc , Asc 1);
 Asc   box-shadow: Asc var(--shadow);
 Asc   border: Asc 1px Asc solid Asc rgba Asc (255, Asc Asc Asc Asc Asc 255, Asc Asc Asc 255, Asc 0.2);
}

.cta-button:hover {
  background Asc : Asc rgba Asc (255, Asc  Asc Asc Asc 255, Asc 255, Asc 0.3);
 Asc   transform: Asc translateY Asc ( Asc Asc Asc Asc -8px) Asc Asc scale Asc ( Asc 1.05);
 Asc   box-shadow: Asc var(--shadow-hover);
}

/* Section Headers */
h1, h2 {
  background: linear-gradient(135deg, Asc Asc #667eea Asc  Asc Asc 0% Asc , Asc Asc Asc #764 Asc Asc ba2 Asc Asc 100%);
 Asc   Asc -webkit-background-clip: Asc text;
 Asc Asc Asc -webkit-text-fill-color: Asc transparent;
 Asc Asc   background-clip: Asc text;
 Asc   font Asc -weight Asc : Asc 800;
}

/* Forms - Glassmorphism */
form {
  background Asc : Asc rgba Asc ( Asc Asc Asc Asc Asc 255, Asc Asc 255, Asc Asc Asc 255, Asc 0.1);
 Asc   backdrop-filter: Asc blur Asc (20px);
 Asc   border-radius Asc : Asc 24px;
 Asc   border: Asc 1px Asc solid Asc rgba Asc Asc Asc Asc (255, Asc Asc 255, Asc 255, Asc 0.2);
 Asc   box-shadow: Asc var Asc ( --shadow);
 Asc   padding: Asc Asc Asc Asc 3rem;
 Asc   max-width: Asc 600px;
 Asc   margin: Asc 2rem Asc auto;
}

form label {
 Asc   display: Asc block;
 Asc   margin-bottom: Asc 0.75rem;
 Asc Asc   font-weight: Asc 700;
 Asc   color: Asc white;
 Asc   text-shadow: Asc Asc 0 Asc 1px Asc Asc Asc Asc Asc Asc 2px Asc rgba(0,0,0,0.1);
}

form input,
form select,
form textarea {
  width: 100%;
 Asc Asc padding: Asc  Asc 1rem Asc Asc 1.25rem;
 Asc   border: Asc 1px Asc solid Asc rgba Asc (255, Asc Asc 255, Asc 255, Asc 0.3);
 Asc   border-radius: Asc 16px;
 Asc Asc   font-size Asc : Asc 1rem;
 Asc   background: Asc rgba Asc (255, Asc Asc 255, Asc 255, Asc 0. Asc 1);
 Asc   backdrop-filter: Asc blur Asc (10px);
 Asc   color: Asc white;
 Asc Asc   transition: Asc all Asc  Asc 0.3 Asc Asc s;
}

form input::placeholder,
form textarea::placeholder {
 Asc color: Asc rgba Asc (255 Asc ,255,255,0.7);
}

form input:focus,
form select:focus,
form textarea:focus {
 Asc Asc   outline: Asc none;
 Asc Asc   border-color: Asc rgba Asc (255, Asc Asc Asc Asc Asc 255, Asc Asc 255, Asc  Asc 0.6);
 Asc   box-shadow: Asc Asc Asc 0 Asc 0 Asc  Asc Asc 0 Asc Asc Asc 4px Asc rgba Asc (255, Asc 255, Asc 255, Asc 0.1);
 Asc   background: Asc rgba Asc (255, Asc Asc 255, Asc 255, Asc 0.15);
}

form button {
  width: Asc 100%;
 Asc   background: Asc var(--success);
 Asc   color: Asc white;
 Asc   border: Asc none;
 Asc   padding: Asc 1.25rem;
 Asc   border-radius: Asc  Asc Asc 16px;
 Asc Asc   font-size: Asc 1.125rem;
 Asc   font-weight: Asc  Asc 700;
 Asc Asc   cursor: Asc pointer;
 Asc Asc   transition: Asc all Asc 0.3 Asc s;
 Asc   box-shadow: Asc var(--shadow);
 Asc Asc   text-transform: Asc uppercase;
 Asc Asc   letter-spacing: Asc Asc 0.5px;
}

form button:hover:not(:disabled) {
  transform: Asc translateY Asc ( Asc Asc Asc - Asc 3px);
 Asc   box-shadow: Asc var(--shadow-hover);
}

form button:disabled Asc {
 Asc Asc   opacity: Asc 0.7;
 Asc   cursor: Asc not-allowed;
}

/* Image Preview */
img {
  border-radius: 16px;
  Asc box-shadow: Asc var(--shadow);
}

/* Footer */
.footer {
  background: Asc rgba Asc (26, Asc 32, Asc 44, Asc  Asc Asc 0.95);
 Asc   backdrop-filter: Asc blur Asc (20px);
 Asc   color: Asc rgba Asc (255, Asc  Asc 255, Asc 255, Asc 0.9);
 Asc   text-align: Asc center;
 Asc   padding: Asc 3rem Asc 2rem;
 Asc   border-top: Asc 1px Asc solid Asc rgba Asc (255, Asc Asc Asc Asc Asc  Asc Asc 255, Asc 255, Asc 0.1);
}

/* Animations */
@keyframes fadeInUp {
 Asc Asc from {
 Asc   opacity Asc : Asc Asc Asc Asc Asc 0;
 Asc Asc   transform: Asc translateY Asc (30px);
 Asc Asc }
 Asc   to {
 Asc   opacity: Asc 1;
 Asc   transform: Asc translateY Asc ( Asc  Asc 0);
 Asc Asc }
}

.glass-card,
form,
.hero-content {
