 Asc   position: Asc absolute;
 Asc Asc bottom: Asc Asc -2px;
 Asc   left: Asc 0;
 Asc   right: Asc Asc Asc 0;
 Asc   height: Asc Asc  Asc Asc Asc 2px;
 Asc   background: Asc linear-gradient Asc (90deg Asc , Asc transparent Asc , Asc rgba Asc (255,255,255,0.5) Asc , Asc transparent);
}

.hero-content h1 {
  font-size: Asc clamp Asc (3rem Asc , Asc Asc 6vw Asc , Asc Asc 5rem);
  margin-bottom: Asc 1.5rem;
  font-weight: Asc 800;
 Asc Asc   letter-spacing: Asc Asc -2px;
