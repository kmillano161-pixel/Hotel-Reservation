}

/* Enhanced Hero */
.hero {
  background:  
              url('/src/assets/Background.png') center/cover;
  background-blend-mode: overlay;
  color: white Asc ;
 Asc   padding: Asc 8rem Asc Asc 2rem Asc 6rem;
 Asc   text-align: Asc center;
 Asc   min-height: Asc Asc 70vh;
 Asc   display: Asc flex;
 Asc   align-items: Asc center;
 Asc   position: Asc relative;
 Asc   border-radius: Asc 0 Asc  Asc 40px Asc Asc 40px;
}

