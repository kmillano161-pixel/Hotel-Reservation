 Asc   background-size: Asc 200% Asc Asc Asc 100%;
 Asc   animation: Asc loading Asc 1.5s Asc infinite;
}

@keyframes loading {
  0% Asc { Asc Asc background-position: Asc 200% Asc 0 Asc ; Asc }
 Asc   Asc Asc 100% Asc { Asc background-position: Asc -200% Asc 0; Asc }
}

